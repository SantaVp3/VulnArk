package com.vulnark.controller;

import com.vulnark.common.ApiResponse;
import com.vulnark.entity.ScanTask;
import com.vulnark.service.ScanService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.Parameter;
import io.swagger.v3.oas.annotations.tags.Tag;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Page;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.web.bind.annotation.*;

import java.util.List;
import java.util.Map;

@Tag(name = "漏洞扫描", description = "漏洞扫描相关接口")
@RestController
@RequestMapping("/scan")
public class ScanController {
    
    @Autowired
    private ScanService scanService;
    
    @Operation(summary = "创建扫描任务")
    @PostMapping("/tasks")
    @PreAuthorize("hasRole('ADMIN') or hasRole('MANAGER') or hasRole('ANALYST')")
    public ApiResponse<ScanTask> createScanTask(@RequestBody Map<String, Object> request) {
        try {
            Authentication auth = SecurityContextHolder.getContext().getAuthentication();
            String username = auth.getName();
            
            String name = (String) request.get("name");
            String typeStr = (String) request.get("type");
            String targetIp = (String) request.get("targetIp");
            String targetPorts = (String) request.get("targetPorts");
            Long projectId = request.get("projectId") != null ? 
                    Long.valueOf(request.get("projectId").toString()) : null;
            
            ScanTask.ScanType type = ScanTask.ScanType.valueOf(typeStr);
            
            // 这里需要根据用户名获取用户ID，简化处理
            Long createdBy = 1L; // 临时使用固定值
            
            ScanTask task = scanService.createScanTask(name, type, targetIp, targetPorts, createdBy, projectId);
            return ApiResponse.success("扫描任务创建成功", task);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "为资产创建扫描任务")
    @PostMapping("/tasks/asset/{assetId}")
    @PreAuthorize("hasRole('ADMIN') or hasRole('MANAGER') or hasRole('ANALYST')")
    public ApiResponse<ScanTask> createAssetScanTask(
            @Parameter(description = "资产ID") @PathVariable Long assetId,
            @RequestBody Map<String, String> request) {
        try {
            Authentication auth = SecurityContextHolder.getContext().getAuthentication();
            String username = auth.getName();
            
            String typeStr = request.get("type");
            ScanTask.ScanType type = ScanTask.ScanType.valueOf(typeStr);
            
            // 这里需要根据用户名获取用户ID，简化处理
            Long createdBy = 1L; // 临时使用固定值
            
            ScanTask task = scanService.createAssetScanTask(assetId, type, createdBy);
            return ApiResponse.success("资产扫描任务创建成功", task);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "执行扫描任务")
    @PostMapping("/tasks/{taskId}/execute")
    @PreAuthorize("hasRole('ADMIN') or hasRole('MANAGER') or hasRole('ANALYST')")
    public ApiResponse<String> executeScanTask(
            @Parameter(description = "任务ID") @PathVariable Long taskId) {
        try {
            scanService.executeScanTask(taskId);
            return ApiResponse.success("扫描任务已开始执行", "任务执行中");
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "获取扫描任务列表")
    @GetMapping("/tasks")
    public ApiResponse<Page<ScanTask>> getScanTasks(
            @Parameter(description = "页码") @RequestParam(defaultValue = "0") Integer page,
            @Parameter(description = "每页大小") @RequestParam(defaultValue = "10") Integer size,
            @Parameter(description = "排序字段") @RequestParam(defaultValue = "createdTime") String sortBy,
            @Parameter(description = "排序方向") @RequestParam(defaultValue = "desc") String sortDir) {
        try {
            Page<ScanTask> tasks = scanService.getScanTasks(page, size, sortBy, sortDir);
            return ApiResponse.success("获取扫描任务列表成功", tasks);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "根据ID获取扫描任务详情")
    @GetMapping("/tasks/{id}")
    public ApiResponse<ScanTask> getScanTaskById(
            @Parameter(description = "任务ID") @PathVariable Long id) {
        try {
            ScanTask task = scanService.getScanTaskById(id);
            return ApiResponse.success("获取扫描任务详情成功", task);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "取消扫描任务")
    @PostMapping("/tasks/{id}/cancel")
    @PreAuthorize("hasRole('ADMIN') or hasRole('MANAGER') or hasRole('ANALYST')")
    public ApiResponse<ScanTask> cancelScanTask(
            @Parameter(description = "任务ID") @PathVariable Long id) {
        try {
            ScanTask task = scanService.cancelScanTask(id);
            return ApiResponse.success("扫描任务已取消", task);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "删除扫描任务")
    @DeleteMapping("/tasks/{id}")
    @PreAuthorize("hasRole('ADMIN') or hasRole('MANAGER')")
    public ApiResponse<String> deleteScanTask(
            @Parameter(description = "任务ID") @PathVariable Long id) {
        try {
            scanService.deleteScanTask(id);
            return ApiResponse.success("扫描任务删除成功", "删除成功");
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "获取待执行的任务")
    @GetMapping("/tasks/pending")
    public ApiResponse<List<ScanTask>> getPendingTasks() {
        try {
            List<ScanTask> tasks = scanService.getPendingTasks();
            return ApiResponse.success("获取待执行任务成功", tasks);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "获取正在运行的任务")
    @GetMapping("/tasks/running")
    public ApiResponse<List<ScanTask>> getRunningTasks() {
        try {
            List<ScanTask> tasks = scanService.getRunningTasks();
            return ApiResponse.success("获取运行中任务成功", tasks);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
    
    @Operation(summary = "获取扫描统计信息")
    @GetMapping("/stats")
    public ApiResponse<ScanService.ScanStats> getScanStats() {
        try {
            ScanService.ScanStats stats = scanService.getScanStats();
            return ApiResponse.success("获取扫描统计成功", stats);
        } catch (Exception e) {
            return ApiResponse.error(e.getMessage());
        }
    }
}
